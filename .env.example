# Server
PORT=5000

# MongoDB Atlas
# mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/ticketbari

# Allowed frontend origin
CLIENT_DOMAIN=https://your-frontend-domain.web.app

# Firebase Admin SDK
FB_SERVICE_KEY=your_base64_encoded_firebase_service_account_json

# Stripe Secret Key (use sk_test_... for development)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here